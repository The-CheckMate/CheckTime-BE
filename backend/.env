# 서버 설정
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# 데이터베이스 설정
DB_HOST=localhost
DB_PORT=5432
DB_NAME=checktime
DB_USER=checktime_user
DB_PASSWORD=1290
DATABASE_URL=postgresql://checktime_user:1290@localhost:5432/checktime

# JWT 설정
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=7f99071ea1b9afb9e5b28275e51a984311757b9a87db48d96d87c26ae00f28c7049a89d76312ed4e2bbd3a78a239608970945975fc302db0ec2dfa9729d4e376
JWT_EXPIRE=7d

# 외부 API 설정
# TIME_IS_API_KEY=holy_moly_shxt

# NTP 서버
NTP_SERVERS=pool.ntp.org,time.google.com,time.cloudflare.com

# 로깅 설정
LOG_LEVEL=info

# 매크로 시스템 설정
ENABLE_CRON=true
MACRO_MAX_CONCURRENT_TASKS=100
MACRO_DEFAULT_TIMEOUT=10000
MACRO_CLEANUP_DAYS=30

# 알림 설정 (선택적)
SLACK_WEBHOOK_URL=your_slack_webhook_url
EMAIL_SERVICE_API_KEY=your_email_api_key